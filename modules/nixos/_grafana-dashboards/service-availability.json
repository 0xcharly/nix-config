{
  "uid": "service-availability",
  "title": "Service availability",
  "description": "Gatus endpoint health scraped from gate-jp:8080. Uptime ratios use gatus_results_total over the dashboard range; push-based external endpoints report duration 0.",
  "tags": ["availability"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Gatus scrape",
      "gridPos": { "h": 6, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "DOWN", "color": "red", "index": 0 },
                "1": { "text": "UP", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "up{job=\"gatus\"}"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Endpoints monitored",
      "gridPos": { "h": 6, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(gatus_results_endpoint_success)"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Endpoints down",
      "gridPos": { "h": 6, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(gatus_results_endpoint_success == 0) OR on() vector(0)"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Overall uptime (range)",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "mappings": [],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 0.99 },
              { "color": "green", "value": 0.999 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value"
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "sum(increase(gatus_results_total{success=\"true\"}[$__range])) / sum(increase(gatus_results_total[$__range]))"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Endpoints down history",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never",
            "lineInterpolation": "stepAfter",
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(gatus_results_endpoint_success == 0) OR on() vector(0)",
          "legendFormat": "down"
        }
      ]
    },
    {
      "id": 6,
      "type": "table",
      "title": "Down endpoints",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "format": "table",
          "expr": "gatus_results_endpoint_success == 0"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Value": true,
              "__name__": true,
              "instance": true,
              "job": true,
              "key": true,
              "host": true
            },
            "indexByName": {},
            "renameByName": {}
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "table",
      "title": "Uptime by endpoint (range)",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "decimals": 3,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Uptime", "desc": false }]
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "format": "table",
          "expr": "sum by (group, name) (increase(gatus_results_total{success=\"true\"}[$__range])) / sum by (group, name) (increase(gatus_results_total[$__range]))"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true
            },
            "indexByName": {},
            "renameByName": {
              "Value": "Uptime"
            }
          }
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Response time",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 14 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "gatus_results_duration_seconds",
          "legendFormat": "{{group}}/{{name}}"
        }
      ]
    }
  ]
}

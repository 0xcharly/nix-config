{
  "uid": "hardware-health",
  "title": "Hardware health",
  "description": "Temperatures (hwmon) and SMART health (smartctl_exporter, physical hosts only). Node metrics filter job .*_system_stats; smartctl metrics live in job smartctl_stats.",
  "tags": ["hardware"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "CPU temperature",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 },
              { "color": "red", "value": 95 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (host) (node_hwmon_temp_celsius{job=~\".*_system_stats\", chip=~\"platform_coretemp_.*|pci0000:00_0000:00:18_3\"})",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "NVMe temperature",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 70 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (host, chip) (node_hwmon_temp_celsius{job=~\".*_system_stats\", chip=~\"nvme_.*\"})",
          "legendFormat": "{{host}} {{chip}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Drive temperature (SMART)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 45 },
              { "color": "red", "value": 55 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "smartctl_device_temperature{job=\"smartctl_stats\", temperature_type=\"current\"}",
          "legendFormat": "{{host}} {{device}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "All hwmon sensors",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (host, chip, sensor) (node_hwmon_temp_celsius{job=~\".*_system_stats\"})",
          "legendFormat": "{{host}} {{chip}} {{sensor}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "SMART overall status",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "FAILED", "color": "red", "index": 0 },
                "1": { "text": "PASSED", "color": "green", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "min by (host, device) (smartctl_device_smart_status{job=\"smartctl_stats\"})",
          "legendFormat": "{{host}} {{device}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "bargauge",
      "title": "NVMe wear",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 80 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "sizing": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "smartctl_device_percentage_used{job=\"smartctl_stats\"}",
          "legendFormat": "{{host}} {{device}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "bargauge",
      "title": "NVMe spare",
      "description": "Remaining spare capacity; red below the 10% threshold.",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 16 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 10 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "sizing": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "smartctl_device_available_spare{job=\"smartctl_stats\"}",
          "legendFormat": "{{host}} {{device}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "table",
      "title": "Power-on hours",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "showHeader": true
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "format": "table",
          "expr": "smartctl_device_power_on_seconds{job=\"smartctl_stats\"}"
        }
      ],
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "__name__": true,
              "instance": true,
              "job": true
            },
            "indexByName": {},
            "renameByName": { "Value": "power-on time" }
          }
        }
      ]
    }
  ]
}

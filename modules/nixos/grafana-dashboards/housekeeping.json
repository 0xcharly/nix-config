{
  "uid": "housekeeping",
  "title": "Housekeeping",
  "description": "Uptime, reboots, clock drift, NixOS generation state (node exporter textfile metrics), kernel versions, /boot headroom, and Prometheus self-monitoring. Node metrics filter job .*_system_stats.",
  "tags": ["housekeeping"],
  "timezone": "browser",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "",
  "time": { "from": "now-7d", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Uptime",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_time_seconds{job=~\".*_system_stats\"} - node_boot_time_seconds{job=~\".*_system_stats\"}",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 2,
      "type": "bargauge",
      "title": "Reboots over range",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "decimals": 0,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "sizing": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "changes(node_boot_time_seconds{job=~\".*_system_stats\"}[$__range])",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Pending reboot",
      "description": "1 when the booted kernel/initrd differ from the current system generation.",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": { "text": "current", "color": "green", "index": 0 },
                "1": { "text": "reboot pending", "color": "orange", "index": 1 }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (host) (nixos_pending_reboot{job=~\".*_system_stats\"})",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Generation age",
      "description": "Time since the last nixos-rebuild switch/boot on each host.",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 6 },
      "fieldConfig": {
        "defaults": {
          "unit": "dtdurations",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1209600 },
              { "color": "red", "value": 2592000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "time() - nixos_system_profile_last_switch_timestamp_seconds{job=~\".*_system_stats\"}",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Clock offset",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_timex_offset_seconds{job=~\".*_system_stats\"}",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Scrape failures by job",
      "description": "0 = healthy; anything above 0 is targets failing to scrape.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum by (job) (1 - up)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "TSDB disk usage",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "prometheus_tsdb_storage_blocks_bytes{job=\"prometheus\"} + prometheus_tsdb_wal_storage_size_bytes{job=\"prometheus\"}",
          "legendFormat": "blocks + WAL"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Ingest rate",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "cps",
          "min": 0,
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(prometheus_tsdb_head_samples_appended_total{job=\"prometheus\"}[$__rate_interval])",
          "legendFormat": "samples/s"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Scrape duration p-worst",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "fillOpacity": 10, "showPoints": "never" }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "max"]
        },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "max by (job) (scrape_duration_seconds)",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "/boot available",
      "description": "ESP headroom. GC only frees /boot indirectly: old generations are pruned at the next nixos-rebuild boot/switch. A host trending toward the red line will fail its next deploy.",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": {
            "fillOpacity": 10,
            "showPoints": "never",
            "thresholdsStyle": { "mode": "line" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "orange", "value": 100000000 },
              { "color": "green", "value": 200000000 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["lastNotNull"]
        },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_filesystem_avail_bytes{job=~\".*_system_stats\", mountpoint=\"/boot\"}",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "/boot used",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 28 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 0.8 },
              { "color": "red", "value": 0.9 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "sizing": "auto"
      },
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "expr": "1 - node_filesystem_avail_bytes{job=~\".*_system_stats\", mountpoint=\"/boot\"} / node_filesystem_size_bytes{job=~\".*_system_stats\", mountpoint=\"/boot\"}",
          "legendFormat": "{{host}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "table",
      "title": "Kernel version",
      "description": "Running kernel per host, from node_uname_info. Compare against Pending reboot: a host on an old kernel with no pending reboot needs a rebuild, not a reboot.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 36 },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "filterable": false }
        },
        "overrides": []
      },
      "options": {
        "sortBy": [{ "displayName": "Host" }]
      },
      "transformations": [
        {
          "id": "filterFieldsByName",
          "options": { "include": { "names": ["host", "release"] } }
        },
        {
          "id": "organize",
          "options": {
            "indexByName": { "host": 0, "release": 1 },
            "renameByName": { "host": "Host", "release": "Kernel" }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "instant": true,
          "format": "table",
          "expr": "node_uname_info{job=~\".*_system_stats\"}"
        }
      ]
    }
  ]
}
